<?xml version="1.0" encoding="utf-8"?>
<!-- Confirmation dialog content for external app launches (RAS-58).
     customView is used instead of MaterialDialog 0.9.x checkBoxPrompt (design §4). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:paddingLeft="24dp"
  android:paddingRight="24dp"
  android:paddingTop="16dp"
  android:paddingBottom="8dp">

  <TextView
    android:id="@+id/externalAppLaunchMessage"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textAppearance="?android:attr/textAppearanceMedium" />

  <CheckBox
    android:id="@+id/externalAppLaunchRemember"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:checked="false"
    android:text="@string/external_app_launch_remember" />
</LinearLayout>
